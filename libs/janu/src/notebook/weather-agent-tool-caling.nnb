{
    "cells": [
        {
            "language": "typescript",
            "source": [
                "// Building AI Agents from Scratch - Daily Dish (Node.js/TypeScript Version)\n// Using LangChain.js with OpenAI and Ollama integrations\n\nimport { ChatOpenAI } from \"@langchain/openai\";\nimport { ChatOllama } from \"@langchain/ollama\";\nimport { ChatPromptTemplate } from \"@langchain/core/prompts\";\nimport { StringOutputParser } from \"@langchain/core/output_parsers\";\nimport { RunnableSequence } from \"@langchain/core/runnables\";\nimport { BaseMessage, HumanMessage, AIMessage } from \"@langchain/core/messages\";\nimport { PDFLoader } from \"@langchain/community/document_loaders/fs/pdf\";\nimport { RecursiveCharacterTextSplitter } from \"@langchain/textsplitters\";\nimport { MemoryVectorStore } from \"langchain/vectorstores/memory\";\nimport { OpenAIEmbeddings } from \"@langchain/openai\";\nimport { createRetrievalChain } from \"langchain/chains/retrieval\";\nimport { createStuffDocumentsChain } from \"langchain/chains/combine_documents\";\nimport * as readline from \"readline\";\nimport * as fs from \"fs\";\n\n// ============================================\n// PART 1: WEATHER AI AGENT\n// ============================================\n\n/**\n * Weather Retrieval Agent - Fetches real-time weather data\n */\nclass WeatherRetrievalAgent {\n  private apiKey: string;\n  private baseUrl: string;\n\n  constructor(apiKey: string) {\n    this.apiKey = apiKey;\n    this.baseUrl = \"http://api.openweathermap.org/data/2.5/weather\";\n  }\n\n  async getWeather(city: string): Promise<any> {\n    try {\n      const params = {\n        q: city,\n        appid: this.apiKey,\n        units: \"metric\"\n      };\n      const url = new URL(this.baseUrl);\n      url.search = new URLSearchParams(params).toString();\n      const response = await fetch(url);\n      const data = await response.json();\n      \n      return {\n        city: city,\n        temperature: data.main.temp,\n        humidity: data.main.humidity,\n        condition: data.weather[0].description\n      };\n    } catch (error) {\n      return { error: \"City not found\" };\n    }\n  }\n}\n\n/**\n * Memory Agent - Stores and recalls conversation history\n */\nclass MemoryAgent {\n  private memory: Array<{ city: string; weather: any; timestamp: Date }>;\n\n  constructor() {\n    this.memory = [];\n  }\n\n  store(city: string, weatherInfo: any): void {\n    this.memory.push({\n      city: city,\n      weather: weatherInfo,\n      timestamp: new Date()\n    });\n  }\n\n  recall(): Array<{ city: string; weather: any; timestamp: Date }> {\n    return this.memory;\n  }\n\n  getLastQuery(): { city: string; weather: any } | null {\n    if (this.memory.length === 0) return null;\n    return this.memory[this.memory.length - 1];\n  }\n}\n\n/**\n * Response Agent - Generates natural language responses\n */\nclass ResponseAgent {\n  generateResponse(city: string, weatherInfo: any): string {\n    if (weatherInfo.error) {\n      return weatherInfo.error;\n    }\n    return `The current weather in ${city} is ${weatherInfo.condition} with a temperature of ${weatherInfo.temperature}°C and humidity of ${weatherInfo.humidity}%.`;\n  }\n}\n\n/**\n * LLM Response Agent - Uses LangChain for enhanced responses\n */\nclass LLMResponseAgent {\n  private llm: ChatOpenAI | ChatOllama;\n\n  constructor(modelType: \"openai\" | \"ollama\" = \"openai\") {\n    if (modelType === \"openai\") {\n      this.llm = new ChatOpenAI({\n        modelName: \"gpt-3.5-turbo\",\n        temperature: 0.7,\n        openAIApiKey: process.env.OPENAI_API_KEY\n      });\n    } else {\n      this.llm = new ChatOllama({\n        model: \"llama2\",\n        temperature: 0.7\n      });\n    }\n  }\n\n  async generateEnhancedResponse(city: string, weatherInfo: any, memoryContext?: any): Promise<string> {\n    const prompt = ChatPromptTemplate.fromMessages([\n      [\"system\", \"You are a helpful weather assistant that provides friendly and informative weather updates.\"],\n      [\"human\", `Current weather in ${city}: ${JSON.stringify(weatherInfo)}. \n      Previous context: ${JSON.stringify(memoryContext)}. \n      Please provide a natural, friendly weather response.`]\n    ]);\n\n    const chain = prompt.pipe(this.llm).pipe(new StringOutputParser());\n    return await chain.invoke({});\n  }\n}\n\n// Weather Agent Workflow\nasync function runWeatherAgent() {\n  console.log(\"=== Weather AI Agent ===\\n\");\n  \n  const WEATHER_API_KEY = \"c0134c1de8cccf7bf3d32bd8f31a3a90\";\n  \n  // Initialize agents\n  const weatherAgent = new WeatherRetrievalAgent(WEATHER_API_KEY);\n  const memoryAgent = new MemoryAgent();\n  const responseAgent = new ResponseAgent();\n  const llmResponseAgent = new LLMResponseAgent(\"openai\");\n\n  // Create readline interface for user input\n  const rl = readline.createInterface({\n    input: process.stdin,\n    output: process.stdout\n  });\n\n  const askQuestion = (query: string): Promise<string> => {\n    return new Promise((resolve) => {\n      rl.question(query, resolve);\n    });\n  };\n\n  const city = await askQuestion(\"Enter city name: \");\n  \n  // Workflow\n  const weatherInfo = await weatherAgent.getWeather(city);\n  memoryAgent.store(city, weatherInfo);\n  const response = responseAgent.generateResponse(city, weatherInfo);\n  \n  console.log(\"\\n\" + response);\n  console.log(\"Memory:\", memoryAgent.recall());\n  \n  // Enhanced response with LLM\n  const enhancedResponse = await llmResponseAgent.generateEnhancedResponse(city, weatherInfo, memoryAgent.getLastQuery());\n  console.log(\"\\nEnhanced LLM Response:\", enhancedResponse);\n  \n  rl.close();\n}\n\n// ============================================\n// PART 2: THE DAILY DISH CHATBOT\n// ============================================\n\n/**\n * Query Understanding Agent - Interprets user intent\n */\nclass QueryUnderstandingAgent {\n  async understandQuery(question: string): Promise<{\n    intent: string;\n    keywords: string[];\n    entities: Record<string, string>;\n  }> {\n    // Simple keyword-based intent detection\n    const lowerQuestion = question.toLowerCase();\n    let intent = \"general\";\n    const keywords: string[] = [];\n    \n    if (lowerQuestion.includes(\"reservation\") || lowerQuestion.includes(\"book\") || lowerQuestion.includes(\"table\")) {\n      intent = \"reservation\";\n      keywords.push(\"reservation\", \"booking\", \"table\");\n    } else if (lowerQuestion.includes(\"menu\") || lowerQuestion.includes(\"dish\") || lowerQuestion.includes(\"food\")) {\n      intent = \"menu\";\n      keywords.push(\"menu\", \"dish\", \"food\", \"cuisine\");\n    } else if (lowerQuestion.includes(\"hours\") || lowerQuestion.includes(\"open\") || lowerQuestion.includes(\"time\")) {\n      intent = \"hours\";\n      keywords.push(\"hours\", \"open\", \"time\");\n    } else if (lowerQuestion.includes(\"price\") || lowerQuestion.includes(\"cost\") || lowerQuestion.includes(\"expensive\")) {\n      intent = \"pricing\";\n      keywords.push(\"price\", \"cost\", \"expensive\");\n    }\n    \n    return {\n      intent,\n      keywords,\n      entities: {}\n    };\n  }\n}\n\n/**\n * Document Retrieval Agent - Searches FAQ PDF\n */\nclass DocumentRetrievalAgent {\n  private vectorStore: MemoryVectorStore | null = null;\n  private retriever: any = null;\n\n  async loadPDF(pdfPath: string): Promise<void> {\n    try {\n      // Check if file exists\n      if (!fs.existsSync(pdfPath)) {\n        console.log(`PDF file not found at ${pdfPath}. Creating sample FAQ data...`);\n        await this.createSampleFAQData();\n        return;\n      }\n\n      // Load PDF using LangChain PDFLoader\n      const loader = new PDFLoader(pdfPath);\n      const docs = await loader.load();\n      \n      // Split documents into chunks\n      const textSplitter = new RecursiveCharacterTextSplitter({\n        chunkSize: 1000,\n        chunkOverlap: 200\n      });\n      const splits = await textSplitter.splitDocuments(docs);\n      \n      // Create vector store with embeddings\n      const embeddings = new OpenAIEmbeddings({\n        openAIApiKey: process.env.OPENAI_API_KEY\n      });\n      \n      this.vectorStore = await MemoryVectorStore.fromDocuments(splits, embeddings);\n      this.retriever = this.vectorStore.asRetriever({\n        k: 3 // Return top 3 relevant chunks\n      });\n      \n      console.log(`Loaded ${splits.length} chunks from PDF`);\n    } catch (error) {\n      console.error(\"Error loading PDF:\", error);\n      await this.createSampleFAQData();\n    }\n  }\n\n  private async createSampleFAQData(): Promise<void> {\n    // Sample FAQ data as fallback\n    const sampleFAQs = [\n      { text: \"Reservations: We accept reservations for parties of 2-8 people. Call (555) 123-4567 or book online. 24-hour cancellation policy applies.\", metadata: { source: \"faq\" } },\n      { text: \"Hours of Operation: Monday-Thursday 11am-10pm, Friday-Saturday 11am-11pm, Sunday 10am-9pm. Brunch served Saturday and Sunday 10am-2pm.\", metadata: { source: \"faq\" } },\n      { text: \"Menu Items: Our signature dishes include Truffle Pasta ($24), Grilled Salmon ($28), and our famous Daily Dish Burger ($16). Vegetarian and gluten-free options available.\", metadata: { source: \"faq\" } },\n      { text: \"Parking: Complimentary valet parking available Friday and Saturday nights. Street parking available other times.\", metadata: { source: \"faq\" } },\n      { text: \"Private Events: The Daily Dish offers private dining for up to 30 guests. Contact events@thedailydish.com for custom menus and pricing.\", metadata: { source: \"faq\" } }\n    ];\n    \n    const embeddings = new OpenAIEmbeddings({\n      openAIApiKey: process.env.OPENAI_API_KEY\n    });\n    \n    this.vectorStore = await MemoryVectorStore.fromTexts(\n      sampleFAQs.map(faq => faq.text),\n      sampleFAQs.map(faq => faq.metadata),\n      embeddings\n    );\n    this.retriever = this.vectorStore.asRetriever({ k: 2 });\n    console.log(\"Created sample FAQ data\");\n  }\n\n  async retrieveRelevantInfo(query: string): Promise<string[]> {\n    if (!this.retriever) {\n      throw new Error(\"Document retriever not initialized. Call loadPDF first.\");\n    }\n    \n    const results = await this.retriever.invoke(query);\n    return results.map((doc: any) => doc.pageContent);\n  }\n}\n\n/**\n * Memory Agent for Chatbot - Stores conversation context\n */\nclass ChatMemoryAgent {\n  private conversationHistory: Array<{\n    role: \"user\" | \"assistant\";\n    content: string;\n    timestamp: Date;\n  }>;\n\n  constructor() {\n    this.conversationHistory = [];\n  }\n\n  addMessage(role: \"user\" | \"assistant\", content: string): void {\n    this.conversationHistory.push({\n      role,\n      content,\n      timestamp: new Date()\n    });\n  }\n\n  getRecentMessages(limit: number = 5): Array<{ role: string; content: string }> {\n    return this.conversationHistory.slice(-limit).map(msg => ({\n      role: msg.role,\n      content: msg.content\n    }));\n  }\n\n  getFullHistory(): Array<{ role: string; content: string; timestamp: Date }> {\n    return this.conversationHistory;\n  }\n\n  clear(): void {\n    this.conversationHistory = [];\n  }\n}\n\n/**\n * LLM Response Agent for Chatbot - Generates friendly responses\n */\nclass ChatbotResponseAgent {\n  private llm: ChatOpenAI | ChatOllama;\n\n  constructor(modelType: \"openai\" | \"ollama\" = \"openai\") {\n    if (modelType === \"openai\") {\n      this.llm = new ChatOpenAI({\n        modelName: \"gpt-3.5-turbo\",\n        temperature: 0.7,\n        openAIApiKey: process.env.OPENAI_API_KEY\n      });\n    } else {\n      this.llm = new ChatOllama({\n        model: \"llama2\",\n        temperature: 0.7\n      });\n    }\n  }\n\n  async generateResponse(\n    question: string,\n    relevantDocs: string[],\n    intent: any,\n    conversationHistory: Array<{ role: string; content: string }>\n  ): Promise<string> {\n    const context = relevantDocs.join(\"\\n\\n\");\n    const historyText = conversationHistory\n      .map(msg => `${msg.role}: ${msg.content}`)\n      .join(\"\\n\");\n    \n    const prompt = ChatPromptTemplate.fromMessages([\n      [\"system\", `You are a friendly customer service agent for \"The Daily Dish\" restaurant. \n      Use the following context to answer questions accurately and helpfully.\n      \n      Context: ${context}\n      \n      Guidelines:\n      - Be warm and welcoming\n      - Provide specific details from the FAQ\n      - If you don't know something, offer to connect them with a human agent\n      - Keep responses concise but informative`],\n      [\"human\", `Conversation history:\n      ${historyText}\n      \n      User question: ${question}\n      Detected intent: ${intent.intent}\n      \n      Please provide a helpful response:`]\n    ]);\n\n    const chain = prompt.pipe(this.llm).pipe(new StringOutputParser());\n    return await chain.invoke({});\n  }\n}\n\n// Main Chatbot Workflow\nasync function runDailyDishChatbot() {\n  console.log(\"\\n=== The Daily Dish Chatbot ===\\n\");\n  console.log(\"Welcome to The Daily Dish! How can I help you today?\");\n  console.log(\"(Type 'exit' to quit, 'clear' to clear memory)\\n\");\n  \n  // Initialize agents\n  const queryAgent = new QueryUnderstandingAgent();\n  const docRetrievalAgent = new DocumentRetrievalAgent();\n  const memoryAgent = new ChatMemoryAgent();\n  const responseAgent = new ChatbotResponseAgent(\"openai\");\n  \n  // Load FAQ PDF\n  const faqPdfPath = \"The_Daily_Dish_FAQ.pdf\";\n  await docRetrievalAgent.loadPDF(faqPdfPath);\n  \n  // Create readline interface\n  const rl = readline.createInterface({\n    input: process.stdin,\n    output: process.stdout\n  });\n  \n  const askQuestion = (query: string): Promise<string> => {\n    return new Promise((resolve) => {\n      rl.question(query, resolve);\n    });\n  };\n  \n  let running = true;\n  \n  while (running) {\n    const userInput = await askQuestion(\"\\nYou: \");\n    \n    if (userInput.toLowerCase() === \"exit\") {\n      console.log(\"\\nThank you for visiting The Daily Dish! Have a great day!\");\n      running = false;\n      break;\n    }\n    \n    if (userInput.toLowerCase() === \"clear\") {\n      memoryAgent.clear();\n      console.log(\"Conversation memory cleared.\");\n      continue;\n    }\n    \n    // Store user message\n    memoryAgent.addMessage(\"user\", userInput);\n    \n    // Step 1: Understand query\n    const intent = await queryAgent.understandQuery(userInput);\n    console.log(`[Debug] Intent detected: ${intent.intent}`);\n    \n    // Step 2: Retrieve relevant documents\n    const relevantDocs = await docRetrievalAgent.retrieveRelevantInfo(userInput);\n    console.log(`[Debug] Retrieved ${relevantDocs.length} relevant documents`);\n    \n    // Step 3: Get conversation history\n    const history = memoryAgent.getRecentMessages(5);\n    \n    // Step 4: Generate response\n    const response = await responseAgent.generateResponse(\n      userInput,\n      relevantDocs,\n      intent,\n      history\n    );\n    \n    // Store assistant response\n    memoryAgent.addMessage(\"assistant\", response);\n    \n    // Display response\n    console.log(`\\nAssistant: ${response}`);\n  }\n  \n  rl.close();\n}\n\n// ============================================\n// ADVANCED: Multi-Agent Orchestration\n// ============================================\n\n/**\n * Orchestrator Agent - Coordinates multiple agents for complex tasks\n */\nclass MultiAgentOrchestrator {\n  private weatherAgent: WeatherRetrievalAgent;\n  private weatherMemory: MemoryAgent;\n  private weatherResponseAgent: ResponseAgent;\n  private chatbotQueryAgent: QueryUnderstandingAgent;\n  private chatbotDocAgent: DocumentRetrievalAgent;\n  private chatbotMemory: ChatMemoryAgent;\n  private chatbotResponseAgent: ChatbotResponseAgent;\n\n  constructor(weatherApiKey: string) {\n    this.weatherAgent = new WeatherRetrievalAgent(weatherApiKey);\n    this.weatherMemory = new MemoryAgent();\n    this.weatherResponseAgent = new ResponseAgent();\n    this.chatbotQueryAgent = new QueryUnderstandingAgent();\n    this.chatbotDocAgent = new DocumentRetrievalAgent();\n    this.chatbotMemory = new ChatMemoryAgent();\n    this.chatbotResponseAgent = new ChatbotResponseAgent(\"openai\");\n  }\n\n  async initialize(): Promise<void> {\n    await this.chatbotDocAgent.loadPDF(\"The_Daily_Dish_FAQ.pdf\");\n  }\n\n  async processRequest(request: string): Promise<string> {\n    // Detect if this is a weather-related request\n    const weatherKeywords = [\"weather\", \"temperature\", \"forecast\", \"rain\", \"sunny\", \"cloudy\"];\n    const isWeatherRequest = weatherKeywords.some(keyword => \n      request.toLowerCase().includes(keyword)\n    );\n    \n    if (isWeatherRequest) {\n      // Extract city name (simplified)\n      const words = request.split(\" \");\n      let city = \"London\"; // default\n      for (const word of words) {\n        if (word[0] === word[0]?.toUpperCase() && word.length > 2) {\n          city = word;\n          break;\n        }\n      }\n      \n      const weatherInfo = await this.weatherAgent.getWeather(city);\n      this.weatherMemory.store(city, weatherInfo);\n      return this.weatherResponseAgent.generateResponse(city, weatherInfo);\n    } else {\n      // Handle restaurant-related request\n      const intent = await this.chatbotQueryAgent.understandQuery(request);\n      const relevantDocs = await this.chatbotDocAgent.retrieveRelevantInfo(request);\n      const history = this.chatbotMemory.getRecentMessages(5);\n      this.chatbotMemory.addMessage(\"user\", request);\n      \n      const response = await this.chatbotResponseAgent.generateResponse(\n        request,\n        relevantDocs,\n        intent,\n        history\n      );\n      \n      this.chatbotMemory.addMessage(\"assistant\", response);\n      return response;\n    }\n  }\n}\n\n// ============================================\n// MAIN EXECUTION\n// ============================================\n\n// async function main() {\n//   console.log(\"=========================================\");\n//   console.log(\"AI Agents from Scratch - Node.js Version\");\n//   console.log(\"=========================================\\n\");\n  \n//   console.log(\"Select an option:\");\n//   console.log(\"1. Run Weather Agent\");\n//   console.log(\"2. Run Daily Dish Chatbot\");\n//   console.log(\"3. Run Multi-Agent Orchestrator\");\n//   console.log(\"4. Run All Demos\");\n  \n//   const rl = readline.createInterface({\n//     input: process.stdin,\n//     output: process.stdout\n//   });\n  \n//   const askQuestion = (query: string): Promise<string> => {\n//     return new Promise((resolve) => {\n//       rl.question(query, resolve);\n//     });\n//   };\n  \n//   const choice = await askQuestion(\"\\nEnter your choice (1-4): \");\n  \n//   switch (choice) {\n//     case \"1\":\n//       await runWeatherAgent();\n//       break;\n//     case \"2\":\n//       await runDailyDishChatbot();\n//       break;\n//     case \"3\":\n//       const orchestrator = new MultiAgentOrchestrator(\"c0134c1de8cccf7bf3d32bd8f31a3a90\");\n//       await orchestrator.initialize();\n      \n//       console.log(\"\\nMulti-Agent Orchestrator Ready!\");\n//       console.log(\"I can handle both weather queries and restaurant questions.\\n\");\n      \n//       let running = true;\n//       while (running) {\n//         const query = await askQuestion(\"You: \");\n//         if (query.toLowerCase() === \"exit\") {\n//           running = false;\n//           break;\n//         }\n//         const response = await orchestrator.processRequest(query);\n//         console.log(`Assistant: ${response}\\n`);\n//       }\n//       break;\n//     case \"4\":\n//       await runWeatherAgent();\n//       console.log(\"\\n\" + \"=\".repeat(50) + \"\\n\");\n//       await runDailyDishChatbot();\n//       break;\n//     default:\n//       console.log(\"Invalid choice\");\n//   }\n  \n//   rl.close();\n// }\n\n// // Run the main function\n// main().catch(console.error);"
            ],
