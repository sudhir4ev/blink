{
    "cells": [
        {
            "language": "typescript",
            "source": [
                "// Building a Reflection Agent with LangGraph (Node.js + TypeScript)\n\n/**\n * In this guided project, you'll learn to build Reflection agents using LangGraph,\n * a powerful tool for creating self-improving AI systems. Reflection agents represent\n * a significant advancement in AI capabilities - they can evaluate their own outputs,\n * identify weaknesses, and iteratively improve through feedback loops.\n */\n\n// ============================================\n// 1. Setup and Dependencies\n// ============================================\n\nimport { ChatOllama } from '@langchain/ollama';\nimport { HumanMessage, AIMessage, BaseMessage } from '@langchain/core/messages';\nimport {\n  ChatPromptTemplate,\n  MessagesPlaceholder,\n} from '@langchain/core/prompts';\nimport { StateGraph, END } from '@langchain/langgraph';\nimport { Annotation } from '@langchain/langgraph';\n\n// ============================================\n// 2. API Disclaimer (Local Setup with Ollama)\n// ============================================\n\n/**\n * This lab uses Ollama to run LLMs locally.\n *\n * Setup Instructions:\n * 1. Download and install Ollama from https://ollama.ai\n * 2. Pull a model: ollama pull llama3.1\n * 3. Start Ollama service: ollama serve\n *\n * For macOS with Homebrew:\n *   brew install ollama\n *   brew services start ollama\n */\n\n// ============================================\n// 3. What is Reflection?\n// ============================================\n\n/**\n * Reflection is a prompting strategy aimed at enhancing the quality and accuracy\n * of outputs generated by AI agents. It involves getting the agent to pause,\n * review, and critique its own outputs before finalizing them.\n *\n * System 1: Reactive and instinctive (quick initial responses)\n * System 2: Reflective and deliberate (carefully reviewing and refining outputs)\n *\n * Reflection agents encourage AI to function more like System 2.\n */\n\n// ============================================\n// 4. Instantiate the Language Model with Ollama\n// ============================================\n\n// Initialize ChatOllama - runs locally\nconst llm = new ChatOllama({\n  model: 'minimax-m2.5:cloud', // 'qwen3.5'. 'deepseek-r1:8b'\n  temperature: 0,\n  // Optional: add other parameters\n  // topP: 0.9,\n  // numPredict: 256,\n});\n\n// For tool calling support, use a model fine-tuned for tools like:\n// ollama pull gpt-oss:20b\n// const toolCallingLLM = new ChatOllama({\n//     model: \"gpt-oss:20b\",\n//     temperature: 0,\n// });\n\n// ============================================\n// 5. Generation Prompt for LinkedIn Posts\n// ============================================\n\nconst generationPrompt = ChatPromptTemplate.fromMessages([\n  [\n    'system',\n    'You are a professional LinkedIn content assistant tasked with crafting engaging, insightful, and well-structured LinkedIn posts. ' +\n      \"Generate the best LinkedIn post possible for the user's request. \" +\n      'If the user provides feedback or critique, respond with a refined version of your previous attempts, improving clarity, tone, or engagement as needed.',\n  ],\n  new MessagesPlaceholder('messages'),\n]);\n\n// ============================================\n// 6. Create the Generation Chain\n// ============================================\n\nconst generateChain = generationPrompt.pipe(llm);\n\n// ============================================\n// 7. Reflection Prompt for LinkedIn Post Critique\n// ============================================\n\nconst reflectionPrompt = ChatPromptTemplate.fromMessages([\n  [\n    'system',\n    `You are a professional LinkedIn content strategist and thought leadership expert. Your task is to critically evaluate the given LinkedIn post and provide a comprehensive critique. Follow these guidelines:\n\n1. Assess the post's overall quality, professionalism, and alignment with LinkedIn best practices.\n2. Evaluate the structure, tone, clarity, and readability of the post.\n3. Analyze the post's potential for engagement (likes, comments, shares) and its effectiveness in building professional credibility.\n4. Consider the post's relevance to the author's industry, audience, or current trends.\n5. Examine the use of formatting (e.g., line breaks, bullet points), hashtags, mentions, and media (if any).\n6. Evaluate the effectiveness of any call-to-action or takeaway.\n\nProvide a detailed critique that includes:\n- A brief explanation of the post's strengths and weaknesses.\n- Specific areas that could be improved.\n- Actionable suggestions for enhancing clarity, engagement, and professionalism.\n\nYour critique will be used to improve the post in the next revision step, so ensure your feedback is thoughtful, constructive, and practical.`,\n  ],\n  new MessagesPlaceholder('messages'),\n]);\n\n// ============================================\n// 8. Create the Reflect Chain\n// ============================================\n\nconst reflectChain = reflectionPrompt.pipe(llm);\n\n// ============================================\n// 9. Define the Agent State\n// ============================================\n\n/**\n * In LangGraph.js, we define state using the Annotation API\n * This replaces Python's TypedDict with Annotated\n */\nconst AgentState = Annotation.Root({\n  messages: Annotation<BaseMessage[]>({\n    reducer: (current, update) => [...(current || []), ...update],\n    default: () => [],\n  }),\n});\n\n// ============================================\n// 10. Define Generation and Reflection Nodes\n// ============================================\n\n/**\n * Generation Node - Produces initial output based on conversation state\n */\nasync function generationNode(\n  state: typeof AgentState.State,\n): Promise<Partial<typeof AgentState.State>> {\n  const generatedPost = await generateChain.invoke({\n    messages: state.messages,\n  });\n  return {\n    messages: [new AIMessage({ content: generatedPost.content as string })],\n  };\n}\n\n/**\n * Reflection Node - Critiques the output and provides feedback for refinement\n *\n * Note: Output is wrapped as HumanMessage because reflection feedback is treated\n * as if it's coming from the user to guide the generation agent.\n */\nasync function reflectionNode(\n  state: typeof AgentState.State,\n): Promise<Partial<typeof AgentState.State>> {\n  const result = await reflectChain.invoke({\n    messages: state.messages,\n  });\n  return {\n    messages: [new HumanMessage({ content: result.content as string })],\n  };\n}\n\n// ============================================\n// 11. Build the Graph\n// ============================================\n\n// Create a new StateGraph with our AgentState\nconst graph = new StateGraph(AgentState)\n  // Add nodes\n  .addNode('generate', generationNode)\n  .addNode('reflect', reflectionNode)\n  // Add edge from reflect back to generate (one-way connection)\n  .addEdge('reflect', 'generate')\n  // Set entry point\n  .setEntryPoint('generate');\n\n// ============================================\n// 12. Add Conditional Routing (Router Node)\n// ============================================\n\n/**\n * Router function that determines whether to continue reflection or end\n *\n * Predefined logic: Check message count to limit iterations\n * Each iteration adds 2 messages (AI response + Human feedback)\n * With max 6 messages = 3 iterations (generate -> reflect -> generate -> reflect -> generate)\n */\nfunction shouldContinue(state: typeof AgentState.State): string {\n  const messageCount = state.messages.length;\n  console.log(`\\n[Router] Current message count: ${messageCount}`);\n  console.log(\n    'Messages:',\n    state.messages.map(\n      (m) => `${m._getType()}: ${m.content?.toString().substring(0, 50)}...`,\n    ),\n  );\n  console.log('-'.repeat(70));\n\n  // Max 6 messages (3 iterations) before ending\n  if (messageCount > 6) {\n    return END;\n  }\n  return 'reflect';\n}\n\n// Add conditional edges from generate node\ngraph.addConditionalEdges('generate', shouldContinue);\n\n// ============================================\n// 13. Compile the Workflow\n// ============================================\n\nconst workflow = graph.compile();\n\n// ============================================\n// 14. Define Input and Execute Workflow\n// ============================================\n\n// Initial user input\nconst inputs: HumanMessage[] = [\n  new HumanMessage({\n    content:\n      'Write a linkedin post on getting a software developer job at IBM under 160 characters',\n  }),\n];\n\n// For the initial state, we need to set the messages\nconst initialState = { messages: inputs };\n\n/**\n * Execute the workflow with async iteration\n * LangGraph.js uses async iterators for streaming\n */\nasync function runWorkflow() {\n  console.log('='.repeat(80));\n  console.log('🚀 Starting Reflection Agent Workflow');\n  console.log('='.repeat(80));\n  console.log('\\n📝 Initial Request:', inputs[0].content);\n  console.log('\\n' + '='.repeat(80) + '\\n');\n\n  // Invoke the workflow\n  const finalState = await workflow.invoke(initialState);\n\n  // Display results\n  const messages = finalState.messages;\n\n  console.log('\\n' + '='.repeat(80));\n  console.log('📊 WORKFLOW RESULTS');\n  console.log('='.repeat(80));\n\n  // Show each message in the conversation\n  for (let i = 0; i < messages.length; i++) {\n    const msg = messages[i];\n    const type = msg._getType().toUpperCase();\n    console.log(`\\n--- Message ${i + 1} [${type}] ---`);\n    console.log(msg.content);\n    console.log('-'.repeat(50));\n  }\n\n  // Show the final generated post (last AI message)\n  const lastAIMessage = messages.filter((m) => m._getType() === 'ai').pop();\n  if (lastAIMessage) {\n    console.log('\\n✨ FINAL GENERATED POST ✨');\n    console.log('='.repeat(40));\n    console.log(lastAIMessage.content);\n    console.log('='.repeat(40));\n  }\n\n  return finalState;\n}\n\n// Run the workflow\n// Uncomment to execute:\n// runWorkflow().catch(console.error);\n\n// ============================================\n// 15. Workflow State Transition Table\n// ============================================\n\n/**\n * | Iteration | Type    | State                | Node      | Next Action |\n * |-----------|---------|----------------------|-----------|-------------|\n * | 1         | Human   | Initial request      | Input     | Generate    |\n * | 1         | AI      | Generated content    | Generate  | Reflect     |\n * | 1         | Human   | Reflection feedback  | Reflect   | Generate    |\n * | 2         | AI      | Revised content      | Generate  | Reflect     |\n * | 2         | Human   | Refinement feedback  | Reflect   | Generate    |\n * | 3         | AI      | Final content        | Generate  | END         |\n */\n\n// ============================================\n// 16. Tool Calling Example (Optional)\n// ============================================\n\n/**\n * For tool calling with Ollama, use a model that supports tool calling\n * like gpt-oss:20b\n *\n * Example:\n *\n * import { tool } from \"@langchain/core/tools\";\n * import { z } from \"zod\";\n *\n * const validateUserSchema = z.object({\n *     user_id: z.number().describe(\"the user ID\"),\n *     addresses: z.array(z.string()).describe(\"Previous addresses as a list of strings\"),\n * });\n *\n * const validateUser = tool(\n *     async ({ user_id, addresses }) => {\n *         console.log(`Validating user ${user_id} with addresses: ${addresses}`);\n *         return true;\n *     },\n *     {\n *         name: \"validate_user\",\n *         description: \"Validate user using historical addresses.\",\n *         schema: validateUserSchema,\n *     }\n * );\n *\n * const toolCallingLLM = new ChatOllama({\n *     model: \"gpt-oss:20b\",\n *     temperature: 0,\n * }).bindTools([validateUser]);\n *\n * const result = await toolCallingLLM.invoke([\n *     new HumanMessage(\"Could you validate user 123? They previously lived at 123 Fake St in Boston MA\")\n * ]);\n *\n * if (result.tool_calls && result.tool_calls.length > 0) {\n *     console.log(result.tool_calls);\n * }\n */\n\n// ============================================\n// 17. Multi-Modal Support with Ollama (Optional)\n// ============================================\n\n/**\n * Ollama supports multi-modal LLMs like gemma3 or llava\n *\n * Example:\n *\n * import * as fs from \"fs/promises\";\n *\n * const multiModalLLM = new ChatOllama({\n *     model: \"gemma3\",  // or \"llava\", \"bakllava\", etc.\n *     temperature: 0,\n * });\n *\n * // Read image and convert to base64\n * const imageBuffer = await fs.readFile(\"path/to/image.jpg\");\n * const base64Image = imageBuffer.toString(\"base64\");\n *\n * const response = await multiModalLLM.invoke([\n *     new HumanMessage({\n *         content: [\n *             { type: \"text\", text: \"What's in this image?\" },\n *             { type: \"image_url\", image_url: { url: `data:image/jpeg;base64,${base64Image}` } }\n *         ]\n *     })\n * ]);\n *\n * console.log(response.content);\n */\n\nconsole.log('\\n✅ Reflection Agent Module Loaded Successfully!');\nconsole.log('To run the workflow, call: runWorkflow()');\n"
            ],
            "outputs": [
                {
                    "items": [
                        {
