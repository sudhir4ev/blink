{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@lib/janu": [
        "libs/janu/src"
      ],
      "@lib/janu/*": [
        "libs/janu/src/*"
      ],
      "@lib/storage": [
        "libs/storage/src"
      ],
      "@lib/storage/*": [
        "libs/storage/src/*"
      ],
      "@repo/genai": [
        "libs/genai/src"
      ],
      "@repo/genai/*": [
        "libs/genai/src/*"
      ],
      "@repo/nodebook": [
        "libs/nodebook/src"
      ],
      "@repo/nodebook/*": [
        "libs/nodebook/src/*"
      ]
    }
  }
}